<?xml version="1.0" encoding="utf-8"?>
<!--
    activity_order_detail.xml — Full details for one specific order.
    Toolbar at top, summary card in the middle, items list fills the rest.
-->
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/colorBackground">

    <include layout="@layout/toolbar" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Order summary card — light blue background for visual grouping -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:cardCornerRadius="12dp"
            app:cardElevation="3dp"
            app:cardBackgroundColor="@color/colorLightBlue">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:id="@+id/textViewDetailOrderId"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Order #"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:textColor="@color/colorTextPrimary"
                    android:layout_marginBottom="8dp" />

                <TextView
                    android:id="@+id/textViewDetailCustomerName"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Customer: "
                    android:textSize="14sp"
                    android:textColor="@color/colorTextPrimary"
                    android:layout_marginBottom="4dp" />

                <TextView
                    android:id="@+id/textViewDetailPhone"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Phone: "
                    android:textSize="14sp"
                    android:textColor="@color/colorTextPrimary"
                    android:layout_marginBottom="4dp" />

                <TextView
                    android:id="@+id/textViewDetailDate"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Date: "
                    android:textSize="14sp"
                    android:textColor="@color/colorTextSecondary"
                    android:layout_marginBottom="10dp" />

                <TextView
                    android:id="@+id/textViewDetailTotal"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Total: USh 0"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:textColor="@color/colorPrimary" />

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="ORDER ITEMS"
            android:textSize="11sp"
            android:textStyle="bold"
            android:textColor="@color/colorTextSecondary"
            android:layout_marginBottom="8dp" />

        <!-- layout_weight=1 + height=0dp makes ListView fill remaining space -->
        <ListView
            android:id="@+id/listViewOrderDetailItems"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:divider="@color/colorLightBlue"
            android:dividerHeight="1dp" />

    </LinearLayout>

</LinearLayout>
