<?xml version="1.0" encoding="utf-8"?>
<!--
    activity_add_product.xml — Add or edit a product.
    Custom Toolbar + ScrollView so the keyboard never hides the Save button.
    All inputs use rounded_input_background for a consistent modern look.
-->
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/colorBackground">

    <include layout="@layout/toolbar" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Title changes between "Add New Product" and "Edit Product" in Java -->
            <TextView
                android:id="@+id/textViewFormTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Add New Product"
                android:textSize="22sp"
                android:textStyle="bold"
                android:textColor="@color/colorTextPrimary"
                android:layout_marginTop="8dp"
                android:layout_marginBottom="16dp" />

            <!-- Product image preview — hidden until the user picks a photo -->
            <ImageView
                android:id="@+id/imagePreview"
                android:layout_width="120dp"
                android:layout_height="120dp"
                android:layout_gravity="center_horizontal"
                android:layout_marginBottom="8dp"
                android:scaleType="centerCrop"
                android:clipToOutline="true"
                android:visibility="gone"
                android:background="@drawable/rounded_image_background"
                android:contentDescription="Product image preview" />

            <!-- Opens the phone gallery so the user can choose a photo -->
            <Button
                android:id="@+id/btnChooseImage"
                android:layout_width="wrap_content"
                android:layout_height="40dp"
                android:layout_gravity="center_horizontal"
                android:layout_marginBottom="20dp"
                android:text="Choose Image"
                android:textColor="@color/colorWhite"
                android:background="@drawable/rounded_button_gold"
                android:paddingStart="24dp"
                android:paddingEnd="24dp"
                android:textAllCaps="false" />

            <!-- Product Name -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Product Name *"
                android:textStyle="bold"
                android:textColor="@color/colorTextPrimary"
                android:layout_marginBottom="6dp" />

            <EditText
                android:id="@+id/editTextProductName"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:hint="e.g. Ballpoint Pen"
                android:inputType="textCapWords"
                android:maxLines="1"
                android:background="@drawable/rounded_input_background"
                android:paddingStart="20dp"
                android:paddingEnd="16dp"
                android:layout_marginBottom="20dp" />

            <!-- Description -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Description *"
                android:textStyle="bold"
                android:textColor="@color/colorTextPrimary"
                android:layout_marginBottom="6dp" />

            <EditText
                android:id="@+id/editTextDescription"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Short description of the product"
                android:inputType="textMultiLine|textCapSentences"
                android:lines="3"
                android:gravity="top|start"
                android:background="@drawable/rounded_input_background"
                android:paddingStart="20dp"
                android:paddingEnd="16dp"
                android:paddingTop="12dp"
                android:paddingBottom="12dp"
                android:layout_marginBottom="20dp" />

            <!-- Price -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Price (USh) *"
                android:textStyle="bold"
                android:textColor="@color/colorTextPrimary"
                android:layout_marginBottom="6dp" />

            <EditText
                android:id="@+id/editTextPrice"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:hint="0.00"
                android:inputType="numberDecimal"
                android:maxLines="1"
                android:background="@drawable/rounded_input_background"
                android:paddingStart="20dp"
                android:paddingEnd="16dp"
                android:layout_marginBottom="20dp" />

            <!-- Stock Quantity -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Stock Quantity *"
                android:textStyle="bold"
                android:textColor="@color/colorTextPrimary"
                android:layout_marginBottom="6dp" />

            <EditText
                android:id="@+id/editTextQuantity"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:hint="0"
                android:inputType="number"
                android:maxLines="1"
                android:background="@drawable/rounded_input_background"
                android:paddingStart="20dp"
                android:paddingEnd="16dp"
                android:layout_marginBottom="28dp" />

            <!-- Save button — gold pill -->
            <Button
                android:id="@+id/buttonSaveProduct"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:text="Save Product"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="@color/colorWhite"
                android:background="@drawable/rounded_button_gold" />

        </LinearLayout>
    </ScrollView>

</LinearLayout>
