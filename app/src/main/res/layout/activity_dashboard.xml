<?xml version="1.0" encoding="utf-8"?>
<!--
    activity_dashboard.xml — Inkify main hub.

    Structure:
      • Custom Toolbar (navy, "Inkify" title)
      • Scrollable content: welcome text + 2×2 CardView grid + Logout button

    Card IDs that DashboardActivity.java references:
        cardViewProducts, cardViewAddProduct, cardViewCreateOrder,
        cardViewOrderHistory, buttonLogout
-->
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/colorBackground">

    <!-- Toolbar at the very top -->
    <include layout="@layout/toolbar" />

    <!-- Scrollable body so the grid works on small screens too -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Welcome header -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Dashboard"
                android:textSize="22sp"
                android:textStyle="bold"
                android:textColor="@color/colorTextPrimary"
                android:layout_marginTop="8dp"
                android:layout_marginBottom="2dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Welcome, Admin"
                android:textSize="14sp"
                android:textColor="@color/colorTextSecondary"
                android:layout_marginBottom="12dp" />

            <!-- ── Business Summary Card ──────────────────────────────────────
                 Shows total orders, revenue, and stock at a glance.
                 DashboardActivity.loadSummaryData() populates the three TextViews.
            -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="20dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="4dp"
                app:cardBackgroundColor="@color/colorPrimary">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <!-- Card title -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Business Summary"
                        android:textColor="@color/colorWhite"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:layout_marginBottom="14dp" />

                    <!-- Three stat columns: Orders | Revenue | Stock -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:weightSum="3">

                        <!-- Column 1: Total Orders -->
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:gravity="center">

                            <ImageView
                                android:layout_width="28dp"
                                android:layout_height="28dp"
                                android:src="@drawable/ic_create_order"
                                android:tint="@color/colorAccent"
                                android:contentDescription="Total orders" />

                            <TextView
                                android:id="@+id/txtTotalOrders"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="0"
                                android:textColor="@color/colorWhite"
                                android:textSize="22sp"
                                android:textStyle="bold"
                                android:layout_marginTop="4dp" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Total Orders"
                                android:textColor="#BBBBBB"
                                android:textSize="11sp" />
                        </LinearLayout>

                        <!-- Column 2: Total Revenue -->
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:gravity="center">

                            <ImageView
                                android:layout_width="28dp"
                                android:layout_height="28dp"
                                android:src="@drawable/ic_money"
                                android:tint="@color/colorAccent"
                                android:contentDescription="Total revenue" />

                            <TextView
                                android:id="@+id/txtTotalRevenue"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="USh 0"
                                android:textColor="@color/colorWhite"
                                android:textSize="16sp"
                                android:textStyle="bold"
                                android:layout_marginTop="4dp"
                                android:gravity="center" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Total Revenue"
                                android:textColor="#BBBBBB"
                                android:textSize="11sp" />
                        </LinearLayout>

                        <!-- Column 3: Total Stock -->
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:gravity="center">

                            <ImageView
                                android:layout_width="28dp"
                                android:layout_height="28dp"
                                android:src="@drawable/ic_products"
                                android:tint="@color/colorAccent"
                                android:contentDescription="Total stock" />

                            <TextView
                                android:id="@+id/txtTotalStock"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="0"
                                android:textColor="@color/colorWhite"
                                android:textSize="22sp"
                                android:textStyle="bold"
                                android:layout_marginTop="4dp" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Total Stock"
                                android:textColor="#BBBBBB"
                                android:textSize="11sp" />
                        </LinearLayout>

                    </LinearLayout>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- ── ROW 1: View Products | Add Product ──────────────────────── -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="12dp">

                <!-- Card: View Products (navy) -->
                <androidx.cardview.widget.CardView
                    android:id="@+id/cardViewProducts"
                    android:layout_width="0dp"
                    android:layout_height="140dp"
                    android:layout_weight="1"
                    android:layout_marginEnd="6dp"
                    app:cardCornerRadius="12dp"
                    app:cardElevation="4dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:background="@color/colorCardProducts"
                        android:padding="12dp">

                        <ImageView
                            android:layout_width="48dp"
                            android:layout_height="48dp"
                            android:src="@drawable/ic_products_large"
                            android:layout_marginBottom="10dp"
                            android:contentDescription="View products" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="View Products"
                            android:textSize="13sp"
                            android:textStyle="bold"
                            android:textColor="@color/colorWhite"
                            android:gravity="center" />

                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <!-- Card: Add Product (gold) -->
                <androidx.cardview.widget.CardView
                    android:id="@+id/cardViewAddProduct"
                    android:layout_width="0dp"
                    android:layout_height="140dp"
                    android:layout_weight="1"
                    android:layout_marginStart="6dp"
                    app:cardCornerRadius="12dp"
                    app:cardElevation="4dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:background="@color/colorCardAdd"
                        android:padding="12dp">

                        <ImageView
                            android:layout_width="48dp"
                            android:layout_height="48dp"
                            android:src="@drawable/ic_add_product_large"
                            android:layout_marginBottom="10dp"
                            android:contentDescription="Add product" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Add Product"
                            android:textSize="13sp"
                            android:textStyle="bold"
                            android:textColor="@color/colorWhite"
                            android:gravity="center" />

                    </LinearLayout>
                </androidx.cardview.widget.CardView>

            </LinearLayout>

            <!-- ── ROW 2: Create Order | Order History ─────────────────────── -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="24dp">

                <!-- Card: Create Order (pink) -->
                <androidx.cardview.widget.CardView
                    android:id="@+id/cardViewCreateOrder"
                    android:layout_width="0dp"
                    android:layout_height="140dp"
                    android:layout_weight="1"
                    android:layout_marginEnd="6dp"
                    app:cardCornerRadius="12dp"
                    app:cardElevation="4dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:background="@color/colorCardOrder"
                        android:padding="12dp">

                        <ImageView
                            android:layout_width="48dp"
                            android:layout_height="48dp"
                            android:src="@drawable/ic_create_order_large"
                            android:layout_marginBottom="10dp"
                            android:contentDescription="Create order" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Create Order"
                            android:textSize="13sp"
                            android:textStyle="bold"
                            android:textColor="@color/colorWhite"
                            android:gravity="center" />

                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <!-- Card: Order History (indigo) -->
                <androidx.cardview.widget.CardView
                    android:id="@+id/cardViewOrderHistory"
                    android:layout_width="0dp"
                    android:layout_height="140dp"
                    android:layout_weight="1"
                    android:layout_marginStart="6dp"
                    app:cardCornerRadius="12dp"
                    app:cardElevation="4dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:background="@color/colorCardHistory"
                        android:padding="12dp">

                        <ImageView
                            android:layout_width="48dp"
                            android:layout_height="48dp"
                            android:src="@drawable/ic_order_history_large"
                            android:layout_marginBottom="10dp"
                            android:contentDescription="Order history" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Order History"
                            android:textSize="13sp"
                            android:textStyle="bold"
                            android:textColor="@color/colorWhite"
                            android:gravity="center" />

                    </LinearLayout>
                </androidx.cardview.widget.CardView>

            </LinearLayout>

            <!-- Logout button — full width, red pill -->
            <Button
                android:id="@+id/buttonLogout"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:text="Logout"
                android:textSize="15sp"
                android:textColor="@color/colorWhite"
                android:background="@drawable/rounded_button_red"
                android:drawableStart="@drawable/ic_logout"
                android:drawableTint="@color/colorWhite"
                android:drawablePadding="8dp" />

        </LinearLayout>
    </ScrollView>

</LinearLayout>
