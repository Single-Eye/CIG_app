<?xml version="1.0" encoding="utf-8"?>
<!--
    activity_login.xml — Modern Inkify login screen.

    Layout structure:
      1. RelativeLayout (navy top section with two overlapping decorative circles
         and a gold avatar circle in the centre).
      2. LinearLayout (white form area below: app title, subtitle, inputs, button).

    IDs that LoginActivity.java expects:
        editTextUsername, editTextPassword, buttonLogin
-->
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:background="@color/colorBackground">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- ── TOP SECTION: navy background with decorative circles ────────── -->
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="240dp"
            android:background="@color/colorPrimary"
            android:clipChildren="false">

            <!-- Decorative circle — large, bleeds off the top-left edge -->
            <View
                android:layout_width="200dp"
                android:layout_height="200dp"
                android:background="@drawable/circle_blue_large"
                android:layout_alignParentTop="true"
                android:layout_alignParentStart="true"
                android:layout_marginTop="-60dp"
                android:layout_marginStart="-60dp" />

            <!-- Decorative circle — medium, top-right area -->
            <View
                android:layout_width="140dp"
                android:layout_height="140dp"
                android:background="@drawable/circle_lightblue_large"
                android:layout_alignParentTop="true"
                android:layout_alignParentEnd="true"
                android:layout_marginTop="40dp"
                android:layout_marginEnd="-30dp" />

            <!-- Gold avatar circle centred in the top section -->
            <FrameLayout
                android:layout_width="90dp"
                android:layout_height="90dp"
                android:layout_centerInParent="true">

                <!-- Gold background circle -->
                <View
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="@drawable/circle_gold" />

                <!-- Person icon on top of the gold circle -->
                <ImageView
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:src="@drawable/ic_person"
                    android:padding="18dp"
                    android:tint="@color/colorWhite"
                    android:scaleType="fitCenter"
                    android:contentDescription="User avatar" />

            </FrameLayout>

        </RelativeLayout>

        <!-- ── FORM SECTION ──────────────────────────────────────────────────── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="28dp"
            android:background="@color/colorBackground">

            <!--
                To add your logo: copy your logo.png to res/drawable/
                then replace the TextView below with:
                    <ImageView
                        android:layout_width="160dp"
                        android:layout_height="60dp"
                        android:src="@drawable/logo"
                        android:scaleType="fitCenter"
                        android:layout_gravity="center_horizontal"
                        android:layout_marginBottom="4dp" />
            -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Inkify"
                android:textSize="28sp"
                android:textStyle="bold"
                android:textColor="@color/colorTextPrimary"
                android:gravity="center"
                android:layout_marginBottom="4dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Sign in to continue"
                android:textSize="14sp"
                android:textColor="@color/colorTextSecondary"
                android:gravity="center"
                android:layout_marginBottom="32dp" />

            <!-- Username input with person icon -->
            <EditText
                android:id="@+id/editTextUsername"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:hint="Username"
                android:inputType="text"
                android:maxLines="1"
                android:background="@drawable/rounded_input_background"
                android:drawableStart="@drawable/ic_username"
                android:drawableTint="@color/colorTextSecondary"
                android:drawablePadding="10dp"
                android:paddingStart="20dp"
                android:paddingEnd="16dp"
                android:paddingTop="4dp"
                android:paddingBottom="4dp"
                android:layout_marginBottom="16dp" />

            <!-- Password input with lock icon -->
            <EditText
                android:id="@+id/editTextPassword"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:hint="Password"
                android:inputType="textPassword"
                android:maxLines="1"
                android:background="@drawable/rounded_input_background"
                android:drawableStart="@drawable/ic_password"
                android:drawableTint="@color/colorTextSecondary"
                android:drawablePadding="10dp"
                android:paddingStart="20dp"
                android:paddingEnd="16dp"
                android:paddingTop="4dp"
                android:paddingBottom="4dp"
                android:layout_marginBottom="28dp" />

            <!-- Sign In button — gold pill shape -->
            <Button
                android:id="@+id/buttonLogin"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:text="Sign In"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="@color/colorWhite"
                android:background="@drawable/rounded_button_gold"
                android:layout_marginStart="8dp"
                android:layout_marginEnd="8dp" />

        </LinearLayout>
    </LinearLayout>
</ScrollView>
