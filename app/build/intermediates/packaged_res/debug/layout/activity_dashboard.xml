<?xml version="1.0" encoding="utf-8"?>
<!--
    activity_dashboard.xml — Inkify main hub.

    Structure:
      • Custom Toolbar (navy, "Inkify" title)
      • Scrollable content: welcome text + 2×2 CardView grid + Logout button

    Card IDs that DashboardActivity.java references:
        cardViewProducts, cardViewAddProduct, cardViewCreateOrder,
        cardViewOrderHistory, buttonLogout
-->
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/colorBackground">

    <!-- Toolbar at the very top -->
    <include layout="@layout/toolbar" />

    <!-- Scrollable body so the grid works on small screens too -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Welcome header -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Dashboard"
                android:textSize="22sp"
                android:textStyle="bold"
                android:textColor="@color/colorTextPrimary"
                android:layout_marginTop="8dp"
                android:layout_marginBottom="2dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Welcome, Admin"
                android:textSize="14sp"
                android:textColor="@color/colorTextSecondary"
                android:layout_marginBottom="20dp" />

            <!-- ── ROW 1: View Products | Add Product ──────────────────────── -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="12dp">

                <!-- Card: View Products (navy) -->
                <androidx.cardview.widget.CardView
                    android:id="@+id/cardViewProducts"
                    android:layout_width="0dp"
                    android:layout_height="140dp"
                    android:layout_weight="1"
                    android:layout_marginEnd="6dp"
                    app:cardCornerRadius="12dp"
                    app:cardElevation="4dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:background="@color/colorCardProducts"
                        android:padding="12dp">

                        <ImageView
                            android:layout_width="48dp"
                            android:layout_height="48dp"
                            android:src="@drawable/ic_products_large"
                            android:layout_marginBottom="10dp"
                            android:contentDescription="View products" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="View Products"
                            android:textSize="13sp"
                            android:textStyle="bold"
                            android:textColor="@color/colorWhite"
                            android:gravity="center" />

                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <!-- Card: Add Product (gold) -->
                <androidx.cardview.widget.CardView
                    android:id="@+id/cardViewAddProduct"
                    android:layout_width="0dp"
                    android:layout_height="140dp"
                    android:layout_weight="1"
                    android:layout_marginStart="6dp"
                    app:cardCornerRadius="12dp"
                    app:cardElevation="4dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:background="@color/colorCardAdd"
                        android:padding="12dp">

                        <ImageView
                            android:layout_width="48dp"
                            android:layout_height="48dp"
                            android:src="@drawable/ic_add_product_large"
                            android:layout_marginBottom="10dp"
                            android:contentDescription="Add product" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Add Product"
                            android:textSize="13sp"
                            android:textStyle="bold"
                            android:textColor="@color/colorWhite"
                            android:gravity="center" />

                    </LinearLayout>
                </androidx.cardview.widget.CardView>

            </LinearLayout>

            <!-- ── ROW 2: Create Order | Order History ─────────────────────── -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="24dp">

                <!-- Card: Create Order (pink) -->
                <androidx.cardview.widget.CardView
                    android:id="@+id/cardViewCreateOrder"
                    android:layout_width="0dp"
                    android:layout_height="140dp"
                    android:layout_weight="1"
                    android:layout_marginEnd="6dp"
                    app:cardCornerRadius="12dp"
                    app:cardElevation="4dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:background="@color/colorCardOrder"
                        android:padding="12dp">

                        <ImageView
                            android:layout_width="48dp"
                            android:layout_height="48dp"
                            android:src="@drawable/ic_create_order_large"
                            android:layout_marginBottom="10dp"
                            android:contentDescription="Create order" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Create Order"
                            android:textSize="13sp"
                            android:textStyle="bold"
                            android:textColor="@color/colorWhite"
                            android:gravity="center" />

                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <!-- Card: Order History (indigo) -->
                <androidx.cardview.widget.CardView
                    android:id="@+id/cardViewOrderHistory"
                    android:layout_width="0dp"
                    android:layout_height="140dp"
                    android:layout_weight="1"
                    android:layout_marginStart="6dp"
                    app:cardCornerRadius="12dp"
                    app:cardElevation="4dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:background="@color/colorCardHistory"
                        android:padding="12dp">

                        <ImageView
                            android:layout_width="48dp"
                            android:layout_height="48dp"
                            android:src="@drawable/ic_order_history_large"
                            android:layout_marginBottom="10dp"
                            android:contentDescription="Order history" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Order History"
                            android:textSize="13sp"
                            android:textStyle="bold"
                            android:textColor="@color/colorWhite"
                            android:gravity="center" />

                    </LinearLayout>
                </androidx.cardview.widget.CardView>

            </LinearLayout>

            <!-- Logout button — full width, red pill -->
            <Button
                android:id="@+id/buttonLogout"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:text="Logout"
                android:textSize="15sp"
                android:textColor="@color/colorWhite"
                android:background="@drawable/rounded_button_red"
                android:drawableStart="@drawable/ic_logout"
                android:drawableTint="@color/colorWhite"
                android:drawablePadding="8dp" />

        </LinearLayout>
    </ScrollView>

</LinearLayout>
